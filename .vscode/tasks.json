{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure (Linux)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "linux-debug"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "build (Linux Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "configure (Linux)",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "build (Linux Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-release"
            ],
            "group": "build",
            "dependsOn": "configure (Linux)",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "clean (Linux)",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "${workspaceFolder}/cmake-build/linux"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "configure (Windows)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "windows-debug"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "build (Windows Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-debug"
            ],
            "group": "build",
            "dependsOn": "configure (Windows)",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Windows Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-release"
            ],
            "group": "build",
            "dependsOn": "configure (Windows)",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean (Windows)",
            "type": "shell",
            "command": "Remove-Item",
            "args": [
                "-Recurse",
                "-Force",
                "${workspaceFolder}/cmake-build/windows"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
